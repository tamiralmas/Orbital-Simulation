    "rendezvous": {
      "title": "Rendezvous with vehicle",
      "description": "Targets another mission vehicle on the shared UTC timeline. Long timelines use a passive phasing wait followed by a bounded, single-revolution terminal Lambert leg and an ideal velocity match. This is deterministic design guidance, not autonomous relative-navigation or proximity-operations GNC.",
      "type": "object",
      "additionalProperties": true,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "const": "rendezvous",
          "title": "Segment type"
        },
        "targetVehicle": {
          "type": "string",
          "title": "Target vehicle",
          "default": "primary",
          "minLength": 1,
          "x-mtp-ref": "vehicle"
        },
        "tofHours": {
          "type": "number",
          "title": "Time of flight (hours)",
          "default": 6,
          "minimum": 0.001
        },
        "direction": {
          "type": "string",
          "title": "Transfer direction",
          "default": "auto",
          "enum": [
            "auto",
            "prograde",
            "retrograde"
          ]
        },
        "maxDvKms": {
          "type": "number",
          "title": "Maximum total dv (km/s)",
          "default": 5,
          "minimum": 0.001
        },
        "terminalRangeKm": {
          "type": "number",
          "title": "Terminal range tolerance (km)",
          "default": 0.001,
          "minimum": 0.000001
        }
      }
    },
    "dock": {
      "title": "Dock / capture vehicle",
      "description": "Joins this vehicle to a target only when the instantaneous range and relative speed are inside explicit capture limits. A joined vehicle follows the target's exact propagated state during later Coast segments. Contact loads, attitude, ports, and collision dynamics are outside this bounded mission-design model.",
