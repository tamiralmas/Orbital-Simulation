{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mission-trajectory-planner.invalid/schema/mission.schema.json",
  "title": "Mission Trajectory Planner mission",
  "description": "Portable mission definition consumed by the buildless Mission Trajectory Planner.",
  "x-mtp-version": "1.24.0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "name",
    "epoch",
    "segments"
  ],
  "properties": {
    "format": {
      "type": "string",
      "enum": [
        "mtp-mission-1",
        "mtp-mission-2"
      ],
      "default": "mtp-mission-2",
      "title": "Portable mission format",
      "description": "Version 2 adds native secondary vehicles; version 1 remains accepted for backward-compatible single-vehicle files."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "title": "Mission name"
    },
    "description": {
      "type": "string",
      "title": "Mission description"
    },
    "epoch": {
      "type": "string",
      "format": "date-time",
      "title": "UTC mission epoch"
    },
    "spacecraft": {
      "type": "object",
      "additionalProperties": true,
      "title": "Spacecraft properties",
      "properties": {
        "name": {
          "type": "string"
        },
        "dryKg": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "propKg": {
          "type": [
            "number",
            "string"
          ],
          "minimum": 0
        },
        "isp": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "thrustN": {
          "type": "number",
          "minimum": 0
        },
        "fovDeg": {
          "type": "number",
          "minimum": 0,
          "maximum": 179
        }
      }
    },
    "uncertainty": {
      "type": "object",
      "additionalProperties": true,
      "description": "Optional nominal covariance and bounded Monte Carlo settings."
    },
    "operations": {
      "type": "object",
      "additionalProperties": true,
      "description": "Optional Track/Data defaults for stations, sensors, eclipses, and fleet comparisons."
    },
    "targetingValidation": {
      "type": "object",
      "additionalProperties": true,
      "description": "Optional reproducible Vary/Achieve validation metadata."
    },
    "segments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "$ref": "#/$defs/launch"
          },
          {
            "$ref": "#/$defs/coast"
          },
          {
            "$ref": "#/$defs/finite_burn"
          },
          {
            "$ref": "#/$defs/gp_orbit"
          },
          {
            "$ref": "#/$defs/libration"
          },
          {
            "$ref": "#/$defs/cr3bp_coast"
          },
          {
            "$ref": "#/$defs/stationkeep"
          },
          {
            "$ref": "#/$defs/coast_to"
          },
          {
            "$ref": "#/$defs/impulse"
          },
          {
            "$ref": "#/$defs/separate"
          },
          {
            "$ref": "#/$defs/rendezvous"
          },
          {
            "$ref": "#/$defs/dock"
          },
          {
            "$ref": "#/$defs/undock"
          },
          {
            "$ref": "#/$defs/hohmann"
          },
          {
            "$ref": "#/$defs/transfer"
          },
          {
            "$ref": "#/$defs/depart"
          },
          {
            "$ref": "#/$defs/insertion"
          },
          {
            "$ref": "#/$defs/flyby"
          },
          {
            "$ref": "#/$defs/observe"
          },
          {
            "$ref": "#/$defs/return"
          },
          {
            "$ref": "#/$defs/land"
          },
          {
            "$ref": "#/$defs/ascend"
          },
          {
            "$ref": "#/$defs/reentry"
          }
        ]
      }
    },
    "vehicles": {
      "type": "array",
      "maxItems": 7,
      "title": "Secondary mission vehicles",
      "description": "Optional dependency-ordered vehicle branches. The root spacecraft and segments remain the reserved primary vehicle. Vehicle-id uniqueness and cross-reference resolution are mission-level constraints that loaders must validate.",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "id",
          "name",
          "segments"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64,
            "pattern": "^[A-Za-z][A-Za-z0-9_-]*$",
            "not": {
              "const": "primary"
            },
            "title": "Mission-local vehicle id",
            "description": "Unique mission-local id. The literal 'primary' is reserved for the root spacecraft."
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "title": "Vehicle display name"
          },
          "color": {
            "type": "string",
            "pattern": "^#[0-9A-Fa-f]{6}$",
            "title": "Trajectory color"
          },
          "spacecraft": {
            "type": "object",
            "additionalProperties": true,
            "title": "Spacecraft properties",
            "properties": {
              "name": {
                "type": "string"
              },
              "dryKg": {
                "type": "number",
                "exclusiveMinimum": 0
              },
              "propKg": {
                "type": [
                  "number",
                  "string"
                ],
                "minimum": 0
              },
              "isp": {
                "type": "number",
                "exclusiveMinimum": 0
              },
              "thrustN": {
                "type": "number",
                "minimum": 0
              },
              "fovDeg": {
                "type": "number",
                "minimum": 0,
                "maximum": 179
              }
            }
          },
          "segments": {
            "type": "array",
            "minItems": 1,
            "title": "Vehicle branch segments",
            "items": {
              "oneOf": [
                {
                  "$ref": "#/$defs/launch"
                },
                {
                  "$ref": "#/$defs/coast"
                },
                {
                  "$ref": "#/$defs/finite_burn"
                },
                {
                  "$ref": "#/$defs/gp_orbit"
                },
                {
                  "$ref": "#/$defs/libration"
                },
                {
                  "$ref": "#/$defs/cr3bp_coast"
                },
                {
                  "$ref": "#/$defs/stationkeep"
                },
                {
                  "$ref": "#/$defs/coast_to"
                },
                {
                  "$ref": "#/$defs/impulse"
                },
                {
                  "$ref": "#/$defs/separate"
                },
                {
                  "$ref": "#/$defs/rendezvous"
                },
                {
                  "$ref": "#/$defs/dock"
                },
                {
                  "$ref": "#/$defs/undock"
                },
                {
                  "$ref": "#/$defs/hohmann"
                },
                {
                  "$ref": "#/$defs/transfer"
                },
                {
                  "$ref": "#/$defs/depart"
                },
                {
                  "$ref": "#/$defs/insertion"
                },
                {
                  "$ref": "#/$defs/flyby"
                },
                {
                  "$ref": "#/$defs/observe"
                },
                {
                  "$ref": "#/$defs/return"
                },
                {
                  "$ref": "#/$defs/land"
                },
                {
                  "$ref": "#/$defs/ascend"
                },
                {
                  "$ref": "#/$defs/reentry"
                }
              ]
            }
          }
        }
      }
    }
  },
  "$defs": {
    "launch": {
      "title": "Launch → MECO / parking orbit",
      "description": "With a named site, starts at the exact selected pad at T+0, then uses a realistically timed guided-ascent bridge to MECO. The bridge follows a smooth vertical-rise/gravity-turn profile and ends on the exact solved conic; vehicle-specific staging and aerodynamics remain outside the Planner, while ascent Δv is bookkept with loss + Earth-rotation estimates. Ordinary launches use a site-compatible direct-ascent plane; Target Plane launches preserve that transfer plane and show the required powered-ascent dogleg. 'MECO ellipse' delivers a suborbital-periapsis transfer ellipse whose apoapsis is the target altitude — add an Insertion (at apoapsis) to circularize, like a real OMS-2 burn. 'direct' inserts straight into the circular orbit (legacy). A blank site with Direct insertion is an orbital-state initialization and does not invent a surface ascent. A launch site constrains inclination to ≥ its latitude.",
      "type": "object",
      "additionalProperties": true,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "const": "launch",
          "title": "Segment type"
        },
        "body": {
          "type": "string",
          "title": "Body",
          "default": "earth",
          "enum": [
            "sun",
            "mercury",
            "venus",
            "earth",
            "moon",
            "mars",
            "phobos",
            "deimos",
            "jupiter",
            "io",
            "europa",
            "ganymede",
            "callisto",
            "saturn",
            "enceladus",
            "titan",
            "uranus",
            "neptune",
            "triton",
            "pluto",
            "charon",
            "ceres",
            "eris",
            "haumea",
            "makemake",
            "vesta",
            "pallas",
            "hygiea",
            "psyche",
            "eros",
            "bennu",
            "ryugu",
            "apophis",
            "didymos"
          ]
        },
        "site": {
          "type": "string",
          "title": "Launch site (Earth)",
          "default": "ksc",
          "enum": [
            "",
            "ksc",
            "starbase",
            "vandenberg",
            "wallops",
            "baikonur",
            "kourou",
            "tanegashima",
            "satish",
            "jiuquan"
          ]
        },
        "ascent": {
          "type": "string",
          "title": "Ascent mode",
          "default": "meco",
          "enum": [
            "meco",
            "direct"
          ]
        },
        "ascentMin": {
          "type": "number",
          "title": "Guided ascent duration (min)",
          "default": 8.5,
          "minimum": 1
        },
        "altKm": {
          "type": "number",
          "title": "Target altitude (km)",
          "default": 200,
          "minimum": 1
        },
        "incDeg": {
          "type": "number",
          "title": "Inclination (°)",
          "default": 28.5
        },
        "raanDeg": {
          "type": "number",
          "title": "RAAN Ω (°)",
          "default": 0
        },
        "targetPlane": {
          "type": "string",
          "title": "Launch window: align plane with",
          "default": "",
          "enum": [
            "",
            "sun",
            "mercury",
            "venus",
            "earth",
            "moon",
            "mars",
            "phobos",
            "deimos",
            "jupiter",
            "io",
            "europa",
            "ganymede",
            "callisto",
            "saturn",
            "enceladus",
            "titan",
            "uranus",
            "neptune",
            "triton",
            "pluto",
            "charon",
            "ceres",
            "eris",
            "haumea",
            "makemake",
            "vesta",
            "pallas",
            "hygiea",
            "psyche",
            "eros",
            "bennu",
            "ryugu",
            "apophis",
            "didymos"
          ]
        },
        "planeTofDays": {
          "type": "number",
          "title": "…as positioned at T+ (days)",
          "default": 3,
          "minimum": 0
        }
      }
    },
    "coast": {
      "title": "Coast (propagate)",
      "description": "Propagates for a fixed duration. 'Kepler' uses the analytic universal-variable solution; 'RK4' integrates two-body motion; 'J2 secular' applies Earth's first-order nodal/periapsis drift; 'adaptive n-body' integrates moving point-mass gravity with error control, and 'adaptive environment' adds selectable drag, solar-radiation pressure with eclipses, and Earth J2-J4. The offline Horizons table is bounded and never extrapolated. SOI crossings are detected by the patched-conic Kepler/RK4 modes.",
      "type": "object",
      "additionalProperties": true,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "const": "coast",
          "title": "Segment type"
        },
        "days": {
          "type": "number",
          "title": "Duration (days)",
          "default": 1,
          "minimum": 0
        },
        "mode": {
          "type": "string",
          "title": "Propagator",
          "default": "kepler",
          "enum": [
            "kepler",
            "rk4",
            "j2-secular",
            "adaptive-nbody",
            "adaptive-environment"
          ]
        },
        "ephemeris": {
          "type": "string",
          "title": "Adaptive ephemeris",
          "default": "catalog",
          "enum": [
            "catalog",
            "planner-horizons"
          ],
          "description": "Optional. Adaptive ephemeris"
        },
        "drag": {
          "type": "string",
          "title": "Atmospheric drag",
          "default": "off",
          "enum": [
            "off",
            "on"
          ],
          "description": "Optional. Atmospheric drag"
        },
        "srp": {
          "type": "string",
          "title": "Solar radiation pressure",
          "default": "off",
          "enum": [
            "off",
            "on"
          ],
          "description": "Optional. Solar radiation pressure"
        },
        "harmonics": {
          "type": "string",
          "title": "Earth zonal harmonics",
          "default": "off",
          "enum": [
            "off",
            "j2",
            "j3",
            "j4"
          ],
          "description": "Optional. Earth zonal harmonics"
        },
        "massKg": {
          "type": "number",
          "title": "Environment mass (kg)",
          "default": "",
          "minimum": 0.001,
          "description": "Optional. Environment mass (kg)"
        },
        "areaM2": {
          "type": "number",
          "title": "Reference area (m²)",
          "default": 10,
          "minimum": 0.001,
          "description": "Optional. Reference area (m²)"
        },
        "cd": {
          "type": "number",
          "title": "Drag coefficient Cd",
          "default": 2.2,
          "minimum": 0,
          "description": "Optional. Drag coefficient Cd"
        },
        "cr": {
          "type": "number",
          "title": "Reflectivity coefficient Cr",
          "default": 1.3,
          "minimum": 0,
          "description": "Optional. Reflectivity coefficient Cr"
        },
        "densityScale": {
          "type": "number",
          "title": "Atmosphere density scale",
          "default": 1,
          "minimum": 0,
          "description": "Optional. Atmosphere density scale"
        }
      }
    },
    "finite_burn": {
      "title": "Finite-thrust maneuver",
      "description": "Integrates gravity, thrust, and mass depletion together with adaptive error control. Unlike an impulse preview, this is real propagation: a prograde burn raises apoapsis continuously while the spacecraft moves along the burn arc.",
      "type": "object",
      "additionalProperties": true,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "const": "finite_burn",
          "title": "Segment type"
        },
        "durationMin": {
          "type": "number",
          "title": "Burn duration (min)",
          "default": 10,
          "minimum": 0.001
        },
        "thrustN": {
          "type": "number",
          "title": "Thrust (N)",
          "default": 2000,
          "minimum": 0
        },
        "ispS": {
          "type": "number",
          "title": "Specific impulse (s)",
          "default": 320,
          "minimum": 1
        },
        "direction": {
          "type": "string",
          "title": "Thrust direction",
          "default": "prograde",
          "enum": [
            "prograde",
            "retrograde",
            "inertial"
          ]
        },
        "dirX": {
          "type": "number",
          "title": "Inertial x (if selected)",
          "default": 1
        },
        "dirY": {
          "type": "number",
          "title": "Inertial y (if selected)",
          "default": 0
        },
        "dirZ": {
          "type": "number",
          "title": "Inertial z (if selected)",
          "default": 0
        },
        "massKg": {
          "type": "number",
          "title": "Start mass override (kg, blank = spacecraft)",
          "default": "",
          "description": "Optional. Start mass override (kg, blank = spacecraft)"
        },
        "gravity": {
          "type": "string",
          "title": "Gravity model",
          "default": "nbody",
          "enum": [
            "nbody",
            "central-relative"
          ]
        }
      }
    },
    "gp_orbit": {
      "title": "GP orbit (SGP4 / SDP4)",
      "description": "Initializes and propagates a NORAD two-line element set with the Vallado SGP4/SDP4 model. The element epoch and TEME frame are reported explicitly. This is a bounded orbit prediction from mean elements, not telemetry or an operational orbit determination.",
      "type": "object",
      "additionalProperties": true,
      "required": [
        "type",
        "line1",
        "line2"
      ],
      "properties": {
        "type": {
          "const": "gp_orbit",
          "title": "Segment type"
        },
        "line1": {
          "type": "string",
          "title": "TLE line 1",
          "default": ""
        },
        "line2": {
          "type": "string",
          "title": "TLE line 2",
          "default": ""
        },
        "days": {
          "type": "number",
          "title": "Duration (days)",
          "default": 2,
          "minimum": 0.001
        },
        "stepMin": {
          "type": "number",
          "title": "Output cadence (minutes)",
          "default": 10,
          "minimum": 0.1
        },
        "strictChecksum": {
          "type": "string",
          "title": "TLE checksum",
          "default": "strict",
          "enum": [
            "strict",
            "relaxed"
          ]
        }
      }
    },
    "libration": {
      "title": "Lagrange-region orbit (CR3BP)",
      "description": "Initializes an ideal circular restricted three-body problem state about Sun-Earth or Earth-Moon L1/L2. Halo and planar Lyapunov families are differentially corrected with a state-transition matrix. Lissajous is explicitly a bounded linear seed, not a periodic-orbit claim. This segment begins a standalone CR3BP plan.",
      "type": "object",
      "additionalProperties": true,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "const": "libration",
          "title": "Segment type"
        },
        "system": {
          "type": "string",
          "title": "Primary-secondary system",
          "default": "earth-moon",
          "enum": [
            "earth-moon",
            "sun-earth"
          ]
        },
        "point": {
          "type": "string",
          "title": "Libration point",
          "default": "L2",
          "enum": [
            "L1",
            "L2"
          ]
        },
        "family": {
          "type": "string",
          "title": "Orbit family",
          "default": "halo",
          "enum": [
            "halo",
            "planar-lyapunov",
            "lissajous"
          ]
        },
        "size": {
          "type": "string",
          "title": "Validated family size",
          "default": "small",
          "enum": [
            "small",
            "medium"
          ]
        },
        "hemisphere": {
          "type": "string",
          "title": "Halo hemisphere",
          "default": "north",
          "enum": [
            "north",
            "south"
          ]
        }
      }
    },
    "cr3bp_coast": {
      "title": "CR3BP adaptive coast",
      "description": "Propagates the full rotating-frame CR3BP equations with adaptive Dormand-Prince 5(4) error control. Duration is measured in the selected reference orbit's characteristic cycles.",
      "type": "object",
      "additionalProperties": true,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "const": "cr3bp_coast",
          "title": "Segment type"
        },
        "cycles": {
          "type": "number",
          "title": "Duration (reference cycles)",
          "default": 2,
          "minimum": 0.01
        },
        "tolerance": {
          "type": "string",
          "title": "Error tolerance",
          "default": "high",
          "enum": [
            "standard",
            "high"
          ]
        }
      }
    },
    "stationkeep": {
      "title": "Libration-orbit stationkeeping",
      "description": "Runs deterministic ideal impulsive reference tracking in the current CR3BP system. It is a design estimate, not flight guidance: navigation error, maneuver execution error, covariance, and operational constraints are not modeled.",
      "type": "object",
      "additionalProperties": true,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "const": "stationkeep",
          "title": "Segment type"
        },
        "cycles": {
          "type": "number",
          "title": "Duration (reference cycles)",
          "default": 2,
          "minimum": 0.01,
          "maximum": 50
        },
        "corrections": {
          "type": "number",
          "title": "Checks per cycle",
          "default": 12,
          "minimum": 1,
          "maximum": 100
        },
        "offsetKm": {
          "type": "number",
          "title": "Initial radial offset (km)",
          "default": 5,
          "minimum": 0
        },
        "maxBurnMs": {
          "type": "number",
          "title": "Max correction (m/s)",
          "default": 5,
          "minimum": 0.001
        }
      }
    },
    "coast_to": {
      "title": "Coast to event",
      "description": "Propagates until periapsis or apoapsis of the current orbit (detected by the sign change of r·v), up to a time limit.",
      "type": "object",
      "additionalProperties": true,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "const": "coast_to",
          "title": "Segment type"
        },
        "event": {
          "type": "string",
          "title": "Stop at",
          "default": "periapsis",
          "enum": [
            "periapsis",
            "apoapsis"
          ]
        },
        "maxDays": {
          "type": "number",
          "title": "Time limit (days)",
          "default": 5,
          "minimum": 0
        },
        "mode": {
          "type": "string",
          "title": "Propagator",
          "default": "kepler",
          "enum": [
            "kepler",
            "rk4"
          ]
        }
      }
    },
    "impulse": {
      "title": "Impulsive maneuver (Δv)",
      "description": "Instantaneous velocity change. VNB frame: V = along velocity (prograde), N = orbit normal, B = V×N (outward). Inertial frame: ecliptic XYZ components.",
      "type": "object",
      "additionalProperties": true,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "const": "impulse",
          "title": "Segment type"
        },
        "frame": {
          "type": "string",
          "title": "Frame",
          "default": "vnb",
          "enum": [
            "vnb",
            "inertial"
          ]
        },
        "dv1": {
          "type": "number",
          "title": "Δv₁ V/x (km/s)",
          "default": 0.1
        },
        "dv2": {
          "type": "number",
          "title": "Δv₂ N/y (km/s)",
          "default": 0
        },
        "dv3": {
          "type": "number",
          "title": "Δv₃ B/z (km/s)",
          "default": 0
        }
      }
    },
    "separate": {
      "title": "Separate from another vehicle",
      "description": "Initializes this vehicle from the exact state of another mission vehicle at the end of a selected parent segment, then applies an optional small separation impulse. Use this as the first segment of a branch vehicle; it does not reset an already-flying vehicle.",
      "type": "object",
      "additionalProperties": true,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "const": "separate",
          "title": "Segment type"
        },
        "fromVehicle": {
          "type": "string",
          "title": "Separate from vehicle",
          "default": "primary",
          "minLength": 1,
          "x-mtp-ref": "vehicle"
        },
        "afterSegment": {
          "type": "number",
          "title": "After parent segment (1-based)",
          "default": 1,
